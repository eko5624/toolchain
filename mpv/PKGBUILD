# Maintainer: nyfair <nyfair2012@gmail.com>
pkgname=(libmpv-git mpv-git)
pkgver=0.35.1
pkgrel=1
pkgdesc='a free, open source, and cross-platform media player'
arch=('x86_64')
url='https://mpv.io/'
makedepends=("yasm"
             "libjpeg-dev"
             "libpng-dev"
             "libsdl2-dev"
             "libsixel-dev"
             "angle-headers-dev"
             "ffmpeg-dev"
             "mujs-dev"
             "rubberband-dev"
             "luajit2-dev" 
             "freetype2-dev"
             "fribidi-dev"
             "harfbuzz-dev"
             "libass-dev"
             "lcms2-dev"
             "libbluray-dev"
             "libdvdnav-dev"
             "libplacebo-dev"
             "shaderc-dev"
             "spirv-cross-dev"
             "vapoursynth-dev"
             "vulkan-dev"
             "zlib-dev")
license=('GPL3')
source=("git+https://github.com/mpv-player/mpv.git#tag=v0.33.1")
md5sums=('SKIP')

build() {
  cd $srcdir/mpv
  export PKG_CONFIG_PATH=/d/msys64/opt/lib/pkgconfig
  export LDFLAGS="$LDFLAGS -lstdc++ -lssp"
  curl -OL https://github.com/mpv-player/mpv/raw/master/video/out/placebo/ra_pl.c
  mv ra_pl.c video/out/placebo/ra_pl.c
  python bootstrap.py
  CC=gcc.exe python waf configure --prefix=/opt --disable-iconv --disable-debug-build --enable-libbluray --enable-dvdnav
  python waf build
  
  # get latest commit sha
  short_sha=$(git rev-parse --short HEAD)
  echo $short_sha > SHORT_SHA
}

package_libmpv-git() {
  export PKGEXT='.pkg.tar.xz'
  mkdir -p $pkgdir/opt/libmpv/include/mpv
  cd $srcdir/mpv/build
  strip -s libmpv-2.dll
  mv libmpv-2.dll $pkgdir/opt/libmpv
  mv libmpv.dll.a $pkgdir/opt/libmpv
  mv ../libmpv/mpv.def $pkgdir/opt/libmpv
  mv ../libmpv/client.h $pkgdir/opt/libmpv/include/mpv
  mv ../libmpv/stream_cb.h $pkgdir/opt/libmpv/include/mpv
  mv ../libmpv/render.h $pkgdir/opt/libmpv/include/mpv
  mv ../libmpv/render_gl.h $pkgdir/opt/libmpv/include/mpv
}

package_mpv-git() {
  export PKGEXT='.pkg.tar.xz'
  mkdir -p $pkgdir/opt/mpv
  cd $srcdir/mpv/build
  mv mpv.exe $pkgdir/opt/mpv
  mv generated/mpv.com $pkgdir/opt/mpv
  strip -s $pkgdir/opt/mpv/mpv.*
  mv ../SHORT_SHA $pkgdir/opt/mpv
  #mv /d/msys64/opt/bin/vulkan-1.dll $pkgdir/opt/mpv
}
